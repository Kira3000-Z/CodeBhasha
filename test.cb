socho Login System Test
saaf

mano admin_naam = "Kira"
mano pin_sahi = 1234

mano input_naam = pucho("Username dalo: ")
mano input_pin = int(pucho("PIN dalo: "))

socho Check logic using 'aur' (and)
agar input_naam == admin_naam aur input_pin == pin_sahi:
    mano login_status = sahi
    dikhao("Login Sahi Hai!")
warna:
    mano login_status = galat
    dikhao("Ghalat Details! Access Denied.")

agar login_status == sahi:
    dikhao("Welcome to the Admin Dashboard.")