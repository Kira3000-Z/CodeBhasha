socho Shopping List Test
saaf

mano saaman = ["Chawal", "Dal", "Aata", "Chini"]
dikhao("Mere paas ye saaman hai:")

phir item mein saaman:
    dikhao("- ", item)

mano naya_saaman = pucho("Aur kya lena hai? ")
saaman.append(naya_saaman)

dikhao("Updated List:")
phir item mein saaman:
    dikhao("- ", item)